<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:padding="20dp">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="20dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/text_primary"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp" />

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Settings"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:fontFamily="sans-serif-black" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/version_card"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Setting Item: Emergency Contacts -->
            <include layout="@layout/item_setting_row" android:id="@+id/set_contacts" />
            
            <!-- Setting Item: Change Voice Command -->
            <include layout="@layout/item_setting_row" android:id="@+id/set_voice" />
            
            <!-- Setting Item: Change Password -->
            <include layout="@layout/item_setting_row" android:id="@+id/set_password" />
            
            <!-- Setting Item: App Lock -->
            <include layout="@layout/item_setting_row" android:id="@+id/set_lock" />
            
            <!-- Setting Item: Start on Boot -->
            <include layout="@layout/item_setting_row" android:id="@+id/set_boot" />
            
            <!-- Setting Item: Dark Mode -->
            <include layout="@layout/item_setting_row" android:id="@+id/set_dark" />
            
            <!-- Setting Item: Notifications -->
            <include layout="@layout/item_setting_row" android:id="@+id/set_notif" />
            
            <!-- Setting Item: About -->
            <include layout="@layout/item_setting_row" android:id="@+id/set_about" />

            <!-- Logout Section -->
            <Button
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:text="Log Out"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_logout_button"
                android:fontFamily="sans-serif-bold" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/version_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_card"
        android:padding="16dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Silent Guard v1.0.2 - Premium Version"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
