<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_glass_card"
    android:clickable="true"
    android:focusable="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/iv_profile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_myplaces"
            app:tint="@color/neon_violet"
            android:background="@drawable/bg_dot_neon"
            android:padding="8dp"
            android:layout_centerVertical="true"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_toEndOf="@id/iv_profile"
            android:layout_marginStart="16dp"
            android:layout_toStartOf="@id/layout_actions"
            android:layout_centerVertical="true">

            <TextView
                android:id="@+id/tv_contact_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contact Name"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-bold"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_contact_phone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+1 234 567 890"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_relation_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_location_tag"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="Family"
                android:textColor="@color/neon_violet"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true">

            <ImageView
                android:id="@+id/iv_edit_contact"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/text_secondary"
                android:padding="4dp"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <ImageView
                android:id="@+id/iv_delete_contact"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="@color/alert_red"
                android:padding="4dp"
                android:layout_marginStart="8dp"
                xmlns:app="http://schemas.android.com/apk/res-auto" />
        </LinearLayout>

    </RelativeLayout>

</LinearLayout>