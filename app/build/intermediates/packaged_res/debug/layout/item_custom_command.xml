<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_glass_card"
    android:clickable="true"
    android:focusable="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/iv_mic"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_btn_speak_now"
            app:tint="@color/neon_violet"
            android:layout_centerVertical="true" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_toEndOf="@id/iv_mic"
            android:layout_marginStart="12dp"
            android:layout_toStartOf="@id/iv_edit"
            android:layout_centerVertical="true">

            <TextView
                android:id="@+id/tv_phrase"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Command Phrase"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-bold"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Action Description"
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/iv_delete"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="@color/text_secondary"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp" />

        <ImageView
            android:id="@+id/iv_edit"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="@color/text_secondary"
            android:layout_toStartOf="@id/iv_delete"
            android:layout_centerVertical="true" />

    </RelativeLayout>

</LinearLayout>