<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:padding="20dp">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="20dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/text_primary"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp" />

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Phone Snatches"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:fontFamily="sans-serif-black" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/test_button"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Voice Command Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/ic_voice"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_btn_speak_now"
                        app:tint="@color/neon_violet" />

                    <TextView
                        android:id="@+id/txt_voice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ic_voice"
                        android:layout_marginStart="16dp"
                        android:text="@string/voice_command"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-bold"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/txt_voice"
                        android:layout_toEndOf="@id/ic_voice"
                        android:layout_marginStart="16dp"
                        android:text="Trigger SOS with a custom phrase"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_voice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="true" />
                </RelativeLayout>

                <!-- AI Indicator -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp"
                    android:layout_marginStart="48dp">
                    
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_status_indicator" />
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="AI voice detection active"
                        android:textColor="@color/success_green"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- Expandable Custom Commands Section -->
                <LinearLayout
                    android:id="@+id/btn_expand_commands"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Saved Emergency Commands"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-bold" />
                        
                    <ImageView
                        android:id="@+id/iv_expand_arrow"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/arrow_down_float"
                        app:tint="@color/neon_violet" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_custom_commands"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp"
                    android:visibility="gone">

                    <!-- Custom Commands Container -->
                    <include layout="@layout/item_custom_command" android:id="@+id/cmd_help" />
                    <include layout="@layout/item_custom_command" android:id="@+id/cmd_pakdo" />
                    <include layout="@layout/item_custom_command" android:id="@+id/cmd_give_phone" />

                    <Button
                        android:id="@+id/btn_add_command"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="8dp"
                        android:layout_gravity="center_horizontal"
                        android:text="+ Add New Command"
                        android:textSize="12sp"
                        android:textColor="@color/neon_violet"
                        android:background="@android:color/transparent"
                        android:textAllCaps="false" />
                </LinearLayout>

            </LinearLayout>

            <!-- Emergency Contacts Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/ic_contacts"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="@color/neon_violet" />

                    <TextView
                        android:id="@+id/txt_contacts_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ic_contacts"
                        android:layout_marginStart="16dp"
                        android:text="Emergency Contacts"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-bold"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/txt_contacts_title"
                        android:layout_toEndOf="@id/ic_contacts"
                        android:layout_marginStart="16dp"
                        android:text="Automatic alerts to trusted circle"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </RelativeLayout>

                <!-- Import From Contacts Button -->
                <Button
                    android:id="@+id/btn_import_contacts"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="20dp"
                    android:text="Import From Contacts"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/bg_neon_button"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="12sp"
                    android:drawableStart="@android:drawable/ic_menu_search"
                    android:drawablePadding="8dp"
                    android:paddingHorizontal="24dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Imported contacts will automatically receive SOS alerts and live location during emergencies."
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium" />

                <!-- Toggles for Alerts -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="48dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SMS Alerts"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp" />
                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_sms_alerts"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:checked="true" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="WhatsApp Alerts"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp" />
                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_whatsapp_alerts"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Live Location Sharing"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp" />
                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_location_sharing"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:checked="true" />
                    </RelativeLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Location will be shared automatically when SOS is triggered"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- Contacts List -->
                <LinearLayout
                    android:id="@+id/layout_contacts_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="24dp">
                    
                    <include layout="@layout/item_emergency_contact" android:id="@+id/contact_1" />
                    <include layout="@layout/item_emergency_contact" android:id="@+id/contact_2" />

                    <Button
                        android:id="@+id/btn_add_contact"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="8dp"
                        android:layout_gravity="center_horizontal"
                        android:text="+ Add Emergency Contact"
                        android:textSize="12sp"
                        android:textColor="@color/neon_violet"
                        android:background="@android:color/transparent"
                        android:textAllCaps="false" />
                </LinearLayout>

                <!-- Test SOS Button -->
                <Button
                    android:id="@+id/btn_test_sos"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:text="Test Emergency Alert"
                    style="@style/NeonButton"
                    android:background="@drawable/bg_sos_pulse"
                    android:elevation="8dp" />

            </LinearLayout>

            <!-- Volume Button Card -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/ic_volume"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_lock_silent_mode"
                    app:tint="@color/neon_violet" />

                <TextView
                    android:id="@+id/txt_volume"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/ic_volume"
                    android:layout_marginStart="16dp"
                    android:text="@string/volume_trigger"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/txt_volume"
                    android:layout_toEndOf="@id/ic_volume"
                    android:layout_marginStart="16dp"
                    android:text="Press volume buttons 3 times"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_volume"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />
            </RelativeLayout>

            <!-- Power Button Card -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/ic_power"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_lock_power_off"
                    app:tint="@color/neon_violet" />

                <TextView
                    android:id="@+id/txt_power"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/ic_power"
                    android:layout_marginStart="16dp"
                    android:text="@string/power_trigger"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/txt_power"
                    android:layout_toEndOf="@id/ic_power"
                    android:layout_marginStart="16dp"
                    android:text="Press power button 3 times"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_power"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:checked="true" />
            </RelativeLayout>

            <!-- Screen Off Mode Card -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/ic_screen"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_menu_view"
                    app:tint="@color/neon_violet" />

                <TextView
                    android:id="@+id/txt_screen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/ic_screen"
                    android:layout_marginStart="16dp"
                    android:text="@string/screen_off_mode"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/txt_screen"
                    android:layout_toEndOf="@id/ic_screen"
                    android:layout_marginStart="16dp"
                    android:text="App works even when screen is off"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_screen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:checked="true" />
            </RelativeLayout>

            <!-- Wrong Password Card -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/ic_pass"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_lock_lock"
                    app:tint="@color/neon_violet" />

                <TextView
                    android:id="@+id/txt_pass"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/ic_pass"
                    android:layout_marginStart="16dp"
                    android:text="@string/wrong_password"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/txt_pass"
                    android:layout_toEndOf="@id/ic_pass"
                    android:layout_marginStart="16dp"
                    android:text="Detects unauthorized access"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_pass"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />
            </RelativeLayout>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/test_button"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/test_voice"
        style="@style/NeonButton"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="20dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
