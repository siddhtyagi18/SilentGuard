<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:padding="20dp">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="20dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/text_primary"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp" />

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Wrong Password Detection"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:fontFamily="sans-serif-black" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginTop="24dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Description Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/ic_pass"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_lock_lock"
                        app:tint="@color/neon_violet" />

                    <TextView
                        android:id="@+id/txt_pass"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ic_pass"
                        android:layout_marginStart="16dp"
                        android:text="Password Detection"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-bold"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/txt_pass"
                        android:layout_toEndOf="@id/ic_pass"
                        android:layout_marginStart="16dp"
                        android:text="Detects unauthorized access and alerts on failed attempts"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_pass"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>
            </LinearLayout>

            <!-- Emergency Contacts Section (Reused) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/ic_contacts"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="@color/neon_violet" />

                    <TextView
                        android:id="@+id/txt_contacts_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ic_contacts"
                        android:layout_marginStart="16dp"
                        android:text="Emergency Contacts"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-bold"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/txt_contacts_title"
                        android:layout_toEndOf="@id/ic_contacts"
                        android:layout_marginStart="16dp"
                        android:text="Automatic alerts to trusted circle"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </RelativeLayout>

                <!-- Import From Contacts Button -->
                <Button
                    android:id="@+id/btn_import_contacts"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="20dp"
                    android:text="Import From Contacts"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/bg_neon_button"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="12sp"
                    android:drawableStart="@android:drawable/ic_menu_search"
                    android:drawablePadding="8dp"
                    android:paddingHorizontal="24dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Imported contacts will automatically receive SOS alerts and live location during emergencies."
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium" />

                <!-- Toggles for Alerts -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="48dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SMS Alerts"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp" />
                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_sms_alerts"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:checked="true" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Live Location Sharing"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp" />
                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_location_sharing"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:checked="true" />
                    </RelativeLayout>
                </LinearLayout>

                <!-- Contacts List -->
                <LinearLayout
                    android:id="@+id/layout_contacts_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="24dp">
                    
                    <Button
                        android:id="@+id/btn_add_contact"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="8dp"
                        android:layout_gravity="center_horizontal"
                        android:text="+ Add Emergency Contact"
                        android:textSize="12sp"
                        android:textColor="@color/neon_violet"
                        android:background="@android:color/transparent"
                        android:textAllCaps="false" />
                </LinearLayout>

                <!-- Test SOS Button -->
                <Button
                    android:id="@+id/btn_test_sos"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:text="Test Emergency Alert"
                    style="@style/NeonButton"
                    android:background="@drawable/bg_sos_pulse"
                    android:elevation="8dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>