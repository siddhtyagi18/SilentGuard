<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:padding="20dp">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="20dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/text_primary"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp" />

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Wrong Password Detection"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:fontFamily="sans-serif-black" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginTop="24dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Description Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/ic_pass"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_lock_lock"
                        app:tint="@color/neon_violet" />

                    <TextView
                        android:id="@+id/txt_pass"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ic_pass"
                        android:layout_marginStart="16dp"
                        android:text="Password Detection"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-bold"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/txt_pass"
                        android:layout_toEndOf="@id/ic_pass"
                        android:layout_marginStart="16dp"
                        android:text="Detects unauthorized access and alerts on failed attempts"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_pass"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>
            </LinearLayout>

            <!-- Actions After Trigger Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:id="@+id/ic_info"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_info_details"
                        app:tint="@color/neon_violet" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ic_info"
                        android:layout_marginStart="12dp"
                        android:text="How It Works"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-bold"
                        android:textSize="14sp" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginVertical="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_lock_lock"
                            app:tint="@color/text_primary" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1"
                            android:textColor="@color/neon_violet"
                            android:textSize="10sp"
                            android:layout_marginTop="4dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wrong Password"
                            android:textColor="@color/text_secondary"
                            android:textSize="8sp"
                            android:gravity="center" />
                    </LinearLayout>

                    <View android:layout_width="12dp" android:layout_height="1dp" android:background="@color/text_secondary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_camera"
                            app:tint="@color/text_primary" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2"
                            android:textColor="@color/neon_violet"
                            android:textSize="10sp"
                            android:layout_marginTop="4dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selfie Capture"
                            android:textColor="@color/text_secondary"
                            android:textSize="8sp"
                            android:gravity="center" />
                    </LinearLayout>

                    <View android:layout_width="12dp" android:layout_height="1dp" android:background="@color/text_secondary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_send"
                            app:tint="@color/text_primary" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3"
                            android:textColor="@color/neon_violet"
                            android:textSize="10sp"
                            android:layout_marginTop="4dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alert Sent"
                            android:textColor="@color/text_secondary"
                            android:textSize="8sp"
                            android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Actions After Trigger Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:id="@+id/ic_trigger"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_compass"
                        app:tint="@color/neon_violet" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ic_trigger"
                        android:layout_marginStart="12dp"
                        android:text="Trigger Condition"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-bold"
                        android:textSize="14sp" />
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="36dp">

                    <TextView
                        android:id="@+id/txt_limit_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Wrong Password Attempts"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/txt_limit_label"
                        android:text="Number of wrong attempts before action"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/btn_minus"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="-"
                            android:textColor="@color/neon_violet"
                            android:textSize="24sp"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:id="@+id/txt_trigger_limit"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="3"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:gravity="center"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:id="@+id/btn_plus"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="+"
                            android:textColor="@color/neon_violet"
                            android:textSize="24sp"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>
                </RelativeLayout>
            </LinearLayout>

            <!-- Actions After Trigger Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:id="@+id/ic_actions"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_lock_power_off"
                        app:tint="@color/neon_violet" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ic_actions"
                        android:layout_marginStart="12dp"
                        android:text="Actions After Trigger"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-bold"
                        android:textSize="14sp" />
                </RelativeLayout>

                <!-- Selfie Switch -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:layout_marginStart="36dp">

                    <ImageView
                        android:id="@+id/ic_cam"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="@color/text_secondary" />

                    <TextView
                        android:id="@+id/txt_cam"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ic_cam"
                        android:layout_marginStart="12dp"
                        android:text="Capture Intruder Selfie"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_capture_selfie"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>

                <!-- Location Switch -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:layout_marginStart="36dp">

                    <ImageView
                        android:id="@+id/ic_loc"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_mylocation"
                        app:tint="@color/text_secondary" />

                    <TextView
                        android:id="@+id/txt_loc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ic_loc"
                        android:layout_marginStart="12dp"
                        android:text="Share Device Location"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_share_location"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>

                <!-- SMS Alert Switch -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:layout_marginStart="36dp">

                    <ImageView
                        android:id="@+id/ic_sms"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_send"
                        app:tint="@color/text_secondary" />

                    <TextView
                        android:id="@+id/txt_sms"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ic_sms"
                        android:layout_marginStart="12dp"
                        android:text="Send Alert Message"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_send_sms"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>

                <!-- Attach Selfie Switch -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="36dp">

                    <ImageView
                        android:id="@+id/ic_gallery"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_gallery"
                        app:tint="@color/text_secondary" />

                    <TextView
                        android:id="@+id/txt_gallery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ic_gallery"
                        android:layout_marginStart="12dp"
                        android:text="Attach Selfie to Alert"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_attach_selfie"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>
            </LinearLayout>

            <!-- Emergency Contacts Section (Reused) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/ic_contacts"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="@color/neon_violet" />

                    <TextView
                        android:id="@+id/txt_contacts_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ic_contacts"
                        android:layout_marginStart="16dp"
                        android:text="Emergency Contacts"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-bold"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/txt_contacts_title"
                        android:layout_toEndOf="@id/ic_contacts"
                        android:layout_marginStart="16dp"
                        android:text="Automatic alerts to trusted circle"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </RelativeLayout>

                <!-- Import From Contacts Button -->
                <Button
                    android:id="@+id/btn_import_contacts"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="20dp"
                    android:text="Import From Contacts"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/bg_neon_button"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="12sp"
                    android:drawableStart="@android:drawable/ic_menu_search"
                    android:drawablePadding="8dp"
                    android:paddingHorizontal="24dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Imported contacts will automatically receive SOS alerts and live location during emergencies."
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium" />

                <!-- Toggles for Alerts -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="48dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SMS Alerts"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp" />
                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_sms_alerts"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:checked="true" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Live Location Sharing"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp" />
                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_location_sharing"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:checked="true" />
                    </RelativeLayout>
                </LinearLayout>

                <!-- Contacts List -->
                <LinearLayout
                    android:id="@+id/layout_contacts_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="24dp">
                    
                    <Button
                        android:id="@+id/btn_add_contact"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="8dp"
                        android:layout_gravity="center_horizontal"
                        android:text="+ Add Emergency Contact"
                        android:textSize="12sp"
                        android:textColor="@color/neon_violet"
                        android:background="@android:color/transparent"
                        android:textAllCaps="false" />
                </LinearLayout>

                <!-- Test SOS Button -->
                <Button
                    android:id="@+id/btn_test_sos"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:text="Test Emergency Alert"
                    style="@style/NeonButton"
                    android:background="@drawable/bg_sos_pulse"
                    android:elevation="8dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>