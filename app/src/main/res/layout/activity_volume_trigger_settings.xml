<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:padding="20dp">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="10dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/text_primary"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Volume Button Trigger"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Press volume buttons 3 times to trigger SOS"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_volume_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/btn_test_volume_trigger"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- How It Works Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_dialog_info"
                        app:tint="@color/neon_violet" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="How It Works"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-bold"
                        android:textSize="14sp" />
                </LinearLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal">

                    <!-- 1st Press -->
                    <LinearLayout
                        android:id="@+id/layout_1st"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_dot_neon"
                            android:src="@android:drawable/ic_lock_silent_mode"
                            android:padding="10dp"
                            app:tint="@color/neon_violet" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="1st"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <View
                        android:id="@+id/line1"
                        android:layout_width="25dp"
                        android:layout_height="1dp"
                        android:background="@color/neon_violet"
                        android:layout_toEndOf="@id/layout_1st"
                        android:layout_alignTop="@id/layout_1st"
                        android:layout_marginTop="20dp"
                        android:alpha="0.5" />

                    <!-- 2nd Press -->
                    <LinearLayout
                        android:id="@+id/layout_2nd"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_toEndOf="@id/line1">
                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_dot_neon"
                            android:src="@android:drawable/ic_lock_silent_mode"
                            android:padding="10dp"
                            app:tint="@color/neon_violet" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="2nd"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <View
                        android:id="@+id/line2"
                        android:layout_width="25dp"
                        android:layout_height="1dp"
                        android:background="@color/neon_violet"
                        android:layout_toEndOf="@id/layout_2nd"
                        android:layout_alignTop="@id/layout_2nd"
                        android:layout_marginTop="20dp"
                        android:alpha="0.5" />

                    <!-- 3rd Press -->
                    <LinearLayout
                        android:id="@+id/layout_3rd"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_toEndOf="@id/line2">
                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_dot_neon"
                            android:src="@android:drawable/ic_lock_silent_mode"
                            android:padding="10dp"
                            app:tint="@color/neon_violet" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="3rd"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />
                    </LinearLayout>
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• 3x Presses: Shares location with contacts"
                        android:textColor="@color/success_green"
                        android:textSize="11sp"
                        android:layout_gravity="center_horizontal" />
                </LinearLayout>
            </LinearLayout>

            <!-- Trigger Settings Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_menu_manage"
                        app:tint="@color/neon_violet" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Trigger Settings"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-bold"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Press Count -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp">
                    <ImageView
                        android:id="@+id/ic_press_count"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        app:tint="@color/neon_violet" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/ic_press_count"
                        android:layout_marginStart="12dp"
                        android:text="Press Count"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="3 Presses >"
                        android:textColor="@color/neon_violet"
                        android:textSize="13sp" />
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/text_secondary"
                        android:layout_alignParentBottom="true"
                        android:alpha="0.2" />
                </RelativeLayout>

                <!-- Press Interval -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp">
                    <ImageView
                        android:id="@+id/ic_interval"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/ic_menu_recent_history"
                        app:tint="@color/neon_violet" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/ic_interval"
                        android:layout_marginStart="12dp"
                        android:text="Press Interval"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Within 3 Seconds >"
                        android:textColor="@color/neon_violet"
                        android:textSize="13sp" />
                </RelativeLayout>
            </LinearLayout>

            <!-- Actions on Trigger Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_menu_send"
                        app:tint="@color/neon_violet" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Actions on Trigger"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-bold"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Share Live Location -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp">
                    <ImageView
                        android:id="@+id/ic_act_loc"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="@color/neon_violet" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/ic_act_loc"
                        android:layout_marginStart="12dp"
                        android:text="Share Live Location"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_share_location"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="true" />
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/text_secondary"
                        android:layout_alignParentBottom="true"
                        android:alpha="0.2" />
                </RelativeLayout>

                <!-- Send SOS Alert (SMS) -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp">
                    <ImageView
                        android:id="@+id/ic_act_sms"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/ic_menu_send"
                        app:tint="@color/neon_violet" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/ic_act_sms"
                        android:layout_marginStart="12dp"
                        android:text="Send SOS Alert (SMS)"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_send_sms"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="true" />
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/text_secondary"
                        android:layout_alignParentBottom="true"
                        android:alpha="0.2" />
                </RelativeLayout>

                <!-- Auto Call Emergency Contact -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp">
                    <ImageView
                        android:id="@+id/ic_act_call"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/ic_menu_call"
                        app:tint="@color/neon_violet" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/ic_act_call"
                        android:layout_marginStart="12dp"
                        android:text="Auto Call Emergency Contact"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_auto_call"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="false" />
                </RelativeLayout>
            </LinearLayout>

            <!-- Emergency Contacts Section (Restored for functionality) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/ic_contacts_sec"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="@color/neon_violet" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ic_contacts_sec"
                        android:layout_marginStart="12dp"
                        android:text="Emergency Contacts"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-bold"
                        android:textSize="14sp" />
                </RelativeLayout>

                <Button
                    android:id="@+id/btn_import_contacts"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="16dp"
                    android:text="Import From Contacts"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/bg_neon_button"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="11sp"
                    android:drawableStart="@android:drawable/ic_menu_search"
                    android:drawablePadding="8dp"
                    android:paddingHorizontal="16dp" />

                <LinearLayout
                    android:id="@+id/layout_contacts_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">
                    <Button
                        android:id="@+id/btn_add_contact"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_gravity="center_horizontal"
                        android:text="+ Add Emergency Contact"
                        android:textSize="11sp"
                        android:textColor="@color/neon_violet"
                        android:background="@android:color/transparent"
                        android:textAllCaps="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- Important Note Card -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:padding="16dp"
                android:layout_marginBottom="24dp">
                <ImageView
                    android:id="@+id/ic_note_shield"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_lock_power_off"
                    app:tint="@color/neon_violet"
                    android:layout_centerVertical="true" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/ic_note_shield"
                    android:layout_toStartOf="@id/iv_note_arrow"
                    android:layout_marginStart="16dp"
                    android:layout_centerVertical="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Important Note"
                        android:textColor="@color/neon_violet"
                        android:fontFamily="sans-serif-bold"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="After triggering SOS, your live location and alert message will be sent to all saved emergency contacts."
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp" />
                </LinearLayout>
                <ImageView
                    android:id="@+id/iv_note_arrow"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/arrow_down_float"
                    android:rotation="-90"
                    app:tint="@color/text_secondary"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />
            </RelativeLayout>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btn_test_volume_trigger"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="-|: Test Volume Button Trigger"
        style="@style/NeonButton"
        android:background="@drawable/bg_neon_button"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="10dp"
        android:textAllCaps="false"
        android:fontFamily="sans-serif-bold" />

</androidx.constraintlayout.widget.ConstraintLayout>