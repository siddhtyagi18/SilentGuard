<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Glassmorphism Container -->
    <LinearLayout
        android:id="@+id/popup_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:background="@drawable/bg_glass_card"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="12dp">

        <!-- Phone Icon with Circular Background -->
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="24dp">
            
            <View
                android:id="@+id/icon_glow"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_dot_neon"
                android:alpha="0.8" />

            <ImageView
                android:id="@+id/iv_warning"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_call"
                app:tint="@color/text_primary" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Do you want to call your\nsaved emergency contact?"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:fontFamily="sans-serif-bold"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tv_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This will call your primary\nemergency contact."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <TextView
            android:id="@+id/tv_sub_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="32dp"
            android:visibility="gone" />

        <!-- Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_negative"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="CANCEL"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_glass_card"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-bold"
                android:layout_marginEnd="10dp" />

            <Button
                android:id="@+id/btn_positive"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="CALL NOW"
                style="@style/NeonButton"
                android:background="@drawable/bg_neon_button"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-bold"
                android:layout_marginStart="10dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Siren Overlay (Visible only when siren playing) -->
    <View
        android:id="@+id/siren_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#4DFF00FF"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>