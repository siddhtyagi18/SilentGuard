<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:padding="20dp">

    <!-- Top Alert Card -->
    <LinearLayout
        android:id="@+id/alert_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_alert_card"
        android:padding="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/text_primary"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:src="@android:drawable/ic_dialog_alert"
            app:tint="@color/text_primary" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMERGENCY SOS"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-black"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your location is being shared"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/share_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Share via"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/alert_card"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/share_options"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/share_title">

        <include layout="@layout/item_share_option" android:id="@+id/opt_sms" />
        <include layout="@layout/item_share_option" android:id="@+id/opt_email" />
        <include layout="@layout/item_share_option" android:id="@+id/opt_whatsapp" />
        <include layout="@layout/item_share_option" android:id="@+id/opt_telegram" />
    </LinearLayout>

    <!-- Map Section -->
    <FrameLayout
        android:id="@+id/map_section"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_glass_card"
        app:layout_constraintTop_toBottomOf="@id/share_options">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_mapmode"
            android:alpha="0.3" />

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_menu_mylocation"
            app:tint="@color/neon_violet" />
    </FrameLayout>

    <!-- Location Card -->
    <LinearLayout
        android:id="@+id/location_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_glass_card"
        android:padding="16dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/map_section">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Current Location"
            android:textColor="@color/text_secondary"
            android:textSize="10sp" />

        <EditText
            android:id="@+id/et_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fetching location..."
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:background="@null"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/txt_last_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Last updated: Just now"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_send_alert"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Send Alert Now"
        style="@style/NeonButton"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="20dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
