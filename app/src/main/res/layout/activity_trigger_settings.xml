<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:padding="20dp">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="20dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/text_primary"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp" />

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Phone Snatches"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:fontFamily="sans-serif-black" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/test_button"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Voice Command Card -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/ic_voice"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_btn_speak_now"
                    app:tint="@color/neon_violet" />

                <TextView
                    android:id="@+id/txt_voice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/ic_voice"
                    android:layout_marginStart="16dp"
                    android:text="@string/voice_command"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/txt_voice"
                    android:layout_toEndOf="@id/ic_voice"
                    android:layout_marginStart="16dp"
                    android:text="Trigger SOS with a custom phrase"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_voice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:checked="true" />
            </RelativeLayout>

            <!-- Volume Button Card -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/ic_volume"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_lock_silent_mode"
                    app:tint="@color/neon_violet" />

                <TextView
                    android:id="@+id/txt_volume"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/ic_volume"
                    android:layout_marginStart="16dp"
                    android:text="@string/volume_trigger"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/txt_volume"
                    android:layout_toEndOf="@id/ic_volume"
                    android:layout_marginStart="16dp"
                    android:text="Press volume buttons 5 times"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_volume"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />
            </RelativeLayout>

            <!-- Power Button Card -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/ic_power"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_lock_power_off"
                    app:tint="@color/neon_violet" />

                <TextView
                    android:id="@+id/txt_power"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/ic_power"
                    android:layout_marginStart="16dp"
                    android:text="@string/power_trigger"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/txt_power"
                    android:layout_toEndOf="@id/ic_power"
                    android:layout_marginStart="16dp"
                    android:text="Press power button 3 times"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_power"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:checked="true" />
            </RelativeLayout>

            <!-- Screen Off Mode Card -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/ic_screen"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_menu_view"
                    app:tint="@color/neon_violet" />

                <TextView
                    android:id="@+id/txt_screen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/ic_screen"
                    android:layout_marginStart="16dp"
                    android:text="@string/screen_off_mode"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/txt_screen"
                    android:layout_toEndOf="@id/ic_screen"
                    android:layout_marginStart="16dp"
                    android:text="App works even when screen is off"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_screen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:checked="true" />
            </RelativeLayout>

            <!-- Wrong Password Card -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/ic_pass"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_lock_lock"
                    app:tint="@color/neon_violet" />

                <TextView
                    android:id="@+id/txt_pass"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/ic_pass"
                    android:layout_marginStart="16dp"
                    android:text="@string/wrong_password"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/txt_pass"
                    android:layout_toEndOf="@id/ic_pass"
                    android:layout_marginStart="16dp"
                    android:text="Detects unauthorized access"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_pass"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />
            </RelativeLayout>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/test_button"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/test_voice"
        style="@style/NeonButton"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="20dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
